# Copie para .env e preencha. Nunca commite .env.
#
# Obrigatório em produção (ver app/core/config.py — validate_settings)
APP_ENV=development
SECRET_KEY=generate-with-secrets-token-hex-or-openssl
ENCRYPTION_KEY=generate-with-python-cryptography-fernet

# Base de dados (Compose usa DB_PASSWORD e DB_PASSWORD_URLENC para URL)
DATABASE_URL=postgresql://backup_user:CHANGE_ME@127.0.0.1:5432/backup_center
DB_PASSWORD=CHANGE_ME
DB_PASSWORD_URLENC=CHANGE_ME

REDIS_URL=redis://:CHANGE_ME@127.0.0.1:6379/0
REDIS_PASSWORD=CHANGE_ME

APP_TIMEZONE=America/Recife

# Opcional: billing Mercado Pago
# MERCADO_PAGO_ACCESS_TOKEN=
# MERCADO_PAGO_PUBLIC_KEY=
# MERCADO_PAGO_WEBHOOK_TOKEN=

# Jump hosts: mapa de slots por host (formato interno). Ex.: default=10,IP:porta=N,...
# Deixe vazio para usar só default interno; em produção defina no .env real, não no Git.
JUMP_HOST_SLOTS_OVERRIDES=default=10

# Flower (monitor Celery): use password forte em produção.
# Browser: Basic Auth. Desative exposição pública ou use VPN/firewall.
FLOWER_BASIC_AUTH=flower_user:CHANGE_THIS_STRONG_PASSWORD
# FLOWER_UNAUTHENTICATED_API deve permanecer false (padrão seguro) — ver docker-compose.yml
